# Copiar a .env.local y completar con los valores del proyecto Supabase.

# Públicas (se exponen al cliente)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sólo server-side (Server Actions / seed). NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# Mercado Pago — Fase 5 (dejar vacío por ahora)
MP_ACCESS_TOKEN=

# Cloudflare Turnstile (captcha en login/registro). La site key es PÚBLICA.
# El secret va en Supabase: Auth → Settings → Enable Captcha (provider: Turnstile).
# Si se deja vacío, no aparece captcha.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
